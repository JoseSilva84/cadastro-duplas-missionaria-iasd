// Schema Prisma — Sistema de Duplas Missionárias — Associação Paulistana

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Perfis de acesso do sistema
enum Perfil {
  ADMINISTRADOR
  COORDENADOR_REGIONAL
  PASTOR_DISTRITAL
  LIDER_REGIOES
}

// Status da dupla missionária
enum StatusDupla {
  ATIVA
  PENDENTE
  INATIVA
}

// Tipo do segundo membro da dupla
enum TipoMembro2 {
  MEMBRO_IASD
}

// Tipo de projeto missionário
enum TipoProjeto {
  CASA_A_CASA
  ESTUDO_BIBLICO
  PEQUENOS_GRUPOS
  ACAO_SOCIAL
  EVANGELISMO_PUBLICO
}

// Classificação principal da dupla (histórico missionário)
enum ClassificacaoDupla {
  A // Já levou pelo menos uma pessoa ao batismo
  B // Já deu estudo bíblico, mas a pessoa não concluiu/não se batizou
  C // Nunca deu estudo bíblico
}

// Subclassificação de atividade atual
enum AtividadeDupla {
  ATIVA   // Está estudando a Bíblia com alguém atualmente
  INATIVA // Não tem estudo bíblico em andamento no momento
}

// Tipo de Estudo Bíblico
enum TipoEstudo {
  UNICO
  PONTO
  CLASSE
}

// Classificação do interessado no estudo bíblico
enum ClassificacaoInteressado {
  A // Quer se batizar E pode batizar
  B // Quer se batizar, MAS não pode (tem impedimento)
  C // Não quer e não pode se batizar
}

// Usuários do sistema
model Usuario {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique
  senha     String
  perfil    Perfil
  ativo     Boolean  @default(true)
  criadoEm DateTime @default(now())

  // Relacionamentos opcionais por perfil
  regiaoId   Int?
  distritoId Int?
  regiao     Regiao?   @relation(fields: [regiaoId], references: [id])
  distrito   Distrito? @relation(fields: [distritoId], references: [id])

  acompanhamentos AcompanhamentoDupla[]
  escolasSabatinaCriadas EscolaSabatinaCadastro[]
}

// Regiões da Associação Paulistana
model Regiao {
  id        Int      @id @default(autoincrement())
  nome      String   @unique
  descricao String?
  cor       String   @default("#1A3A6B") // cor identificadora do card
  criadoEm DateTime @default(now())

  // Pastor Regional
  fotoConselheiro  String? // base64 ou URL
  nomeConselheiro  String?
  cargoConselheiro String? // ex: "Pastor Regional", "Conselheiro"

  distritos Distrito[]
  usuarios  Usuario[]
}

// Distritos dentro de cada região
model Distrito {
  id        Int      @id @default(autoincrement())
  nome      String
  regiaoId  Int
  membros   Int      @default(0)
  criadoEm DateTime @default(now())

  // Pastor Distrital
  fotoPastor  String? // base64 ou URL
  nomePastor  String?
  cargoPastor String? // ex: "Pastor Distrital"

  regiao   Regiao    @relation(fields: [regiaoId], references: [id])
  duplas   Dupla[]
  usuarios Usuario[]
  igrejas  Igreja[]
  escolasSabatina EscolaSabatinaCadastro[]
}

// Igrejas/congregações do distrito
model Igreja {
  id         Int      @id @default(autoincrement())
  nome       String
  distritoId Int
  membros    Int      @default(0)
  criadoEm  DateTime @default(now())
  endereco   String?
  fotoIgreja String? // base64 ou URL/referencia Firebase

  // Diretor de Ministerio Pessoal
  fotoDiretorMinisterioPessoal String? // base64 ou URL/referencia Firebase
  nomeDiretorMinisterioPessoal String?
  enderecoDiretorMinisterioPessoal String?
  whatsappDiretorMinisterioPessoal String?
  dataNascimentoDiretorMinisterioPessoal DateTime?

  // Coordenador de Interessados
  fotoCoordInteressados  String? // base64 ou URL
  nomeCoordInteressados  String?
  cargoCoordInteressados String? @default("Coordenador de Interessados")
  telefoneCoordInteressados String?
  enderecoCoordInteressados String?
  dataNascimentoCoordInteressados DateTime?

  distrito Distrito @relation(fields: [distritoId], references: [id])
  duplas   Dupla[]
  escolasSabatina EscolaSabatinaCadastro[]
}

// Duplas Missionárias
model Dupla {
  id         Int      @id @default(autoincrement())

  // Localização
  regiaoNome  String
  distritoId  Int
  igrejaId    Int?
  bairro      String

  // Fotos (armazenadas como base64 no Firebase Storage)
  fotoLider   String?
  fotoMembro2 String?

  // Tipo de projeto
  tipoProjeto TipoProjeto

  // Membro 1 (líder)
  liderNome    String
  liderTelefone String?
  liderEmail   String?
  liderIgreja  String?

  // Membro 2
  membro2Tipo     TipoMembro2
  membro2Nome     String
  membro2Telefone String?
  membro2Email    String?

  // Acompanhamento
  estudoBiblico      String?
  statusEstudoBiblico String?
  statusEvangelismo  String?
  batismos           Int      @default(0)

  // Classificação missionária
  classificacaoDupla   ClassificacaoDupla?
  atividadeDupla       AtividadeDupla?
  levouPessoaBatismo   Boolean?
  jaDeuEstudoBiblico   Boolean?
  estudoAtualEmAndamento Boolean?

  // Membro 1 — campos extras
  liderDataNascimento  DateTime?
  liderDataBatismo     DateTime?
  liderSexo            String?
  liderEndereco        String?

  // Membro 2 — campos extras
  membro2DataNascimento DateTime?
  membro2DataBatismo    DateTime?
  membro2Sexo           String?
  membro2Endereco       String?

  // Acompanhamento do coordenador
  ultimoAcompanhamento  DateTime?

  // Metadados
  status           StatusDupla @default(ATIVA)
  pessoasAlcancadas Int        @default(0)
  observacoes      String?
  dataInicio       DateTime    @default(now())
  criadoEm        DateTime    @default(now())
  atualizadoEm    DateTime    @updatedAt

  // Relacionamentos
  distrito       Distrito          @relation(fields: [distritoId], references: [id])
  igreja         Igreja?           @relation(fields: [igrejaId], references: [id])
  estudosBiblicos EstudoBiblico[]
  evangelismos   Evangelismo[]
  acompanhamentos DuplaAcompanhamento[]
  atas            AtaDupla[]
  escolasSabatina EscolaSabatinaDupla[]
}

// Atas geradas pelas duplas missionarias
model AtaDupla {
  id        Int      @id @default(autoincrement())
  duplaId   Int
  titulo    String?
  conteudo  String?
  criadoEm  DateTime @default(now())

  dupla Dupla @relation(fields: [duplaId], references: [id], onDelete: Cascade)
}

// Estudos Bíblicos cadastrados para acompanhamento
model EstudoBiblico {
  id             Int      @id @default(autoincrement())
  nomeEstudante  String
  endereco       String
  cidade         String
  estado         String
  whatsapp       String
  diaEstudo      String
  horarioEstudo  String?
  duplaId        Int
  serie          String
  licaoAtual     Int
  tipoEstudo               TipoEstudo               @default(UNICO)
  sexo                     String?
  classificacaoInteressado ClassificacaoInteressado?
  motivoImpedimento        String?
  vaIgreja                 Boolean?
  leBiblia                 Boolean?
  estudaLicao              Boolean?
  devolveDizimos           Boolean?
  cultoFamiliar            Boolean?
  criadoEm       DateTime @default(now())
  atualizadoEm   DateTime @updatedAt

  dupla        Dupla          @relation(fields: [duplaId], references: [id])
  participantes Participante[]
}

// Participantes de Ponto de Estudo e Classe Bíblica
model Participante {
  id                       Int                      @id @default(autoincrement())
  estudoBiblicoId          Int
  nome                     String
  whatsapp                 String?
  sexo                     String?
  endereco                 String?
  classificacaoInteressado ClassificacaoInteressado?
  motivoImpedimento        String?
  criadoEm                DateTime                 @default(now())

  estudo EstudoBiblico @relation(fields: [estudoBiblicoId], references: [id], onDelete: Cascade)
}

// Cadastros de evangelismo
model Evangelismo {
  id              Int      @id @default(autoincrement())
  nomePessoa      String
  endereco        String
  cidade          String
  estado          String
  whatsapp        String
  diaEvangelismo  String
  duplaId         Int
  serie           String
  estudoAtual     Int
  criadoEm        DateTime @default(now())
  atualizadoEm    DateTime @updatedAt

  dupla Dupla @relation(fields: [duplaId], references: [id])
}

// Registro de saída/acompanhamento do Coordenador Missionário
model AcompanhamentoDupla {
  id            Int      @id @default(autoincrement())
  dataSaida     DateTime
  coordenadorId Int
  observacoes   String?
  criadoEm     DateTime @default(now())

  coordenador Usuario               @relation(fields: [coordenadorId], references: [id])
  duplas      DuplaAcompanhamento[]
}

// Tabela de junção dupla <-> acompanhamento
model DuplaAcompanhamento {
  id               Int @id @default(autoincrement())
  acompanhamentoId Int
  duplaId          Int

  acompanhamento AcompanhamentoDupla @relation(fields: [acompanhamentoId], references: [id], onDelete: Cascade)
  dupla          Dupla               @relation(fields: [duplaId], references: [id])
}

// Cadastro de indicadores da Escola Sabatina por igreja
model EscolaSabatinaCadastro {
  id                       Int      @id @default(autoincrement())
  distritoId               Int
  igrejaId                 Int
  unidadesAcao             Int      @default(0)
  classeProfessores        Int      @default(0)
  classeInteressados       Int      @default(0)
  visitasDiretores         Int      @default(0)
  visitasProfessores       Int      @default(0)
  visitasAlunos            Int      @default(0)
  quantidadePequenosGrupos Int      @default(0)
  observacoes              String?
  criadoPorId              Int?
  criadoEm                 DateTime @default(now())
  atualizadoEm             DateTime @updatedAt

  distrito Distrito @relation(fields: [distritoId], references: [id])
  igreja   Igreja   @relation(fields: [igrejaId], references: [id])
  criadoPor Usuario? @relation(fields: [criadoPorId], references: [id])
  duplas   EscolaSabatinaDupla[]
}

model EscolaSabatinaDupla {
  id                       Int @id @default(autoincrement())
  escolaSabatinaCadastroId Int
  duplaId                  Int

  cadastro EscolaSabatinaCadastro @relation(fields: [escolaSabatinaCadastroId], references: [id], onDelete: Cascade)
  dupla    Dupla                  @relation(fields: [duplaId], references: [id])

  @@unique([escolaSabatinaCadastroId, duplaId])
}

// Indicadores consolidados da Escola Sabatina
model EscolaSabatinaResumo {
  id                    Int      @id @default(1)
  unidadesAcao          Int      @default(0)
  classeProfessores     Int      @default(0)
  classeInteressados    Int      @default(0)
  visitasDiretores      Int      @default(0)
  visitasProfessores    Int      @default(0)
  visitasAlunos         Int      @default(0)
  quantidadePequenosGrupos Int   @default(0)
  atualizadoEm          DateTime @updatedAt
}
